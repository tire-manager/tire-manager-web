[debug] [2026-05-21T03:52:28.238Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/tires-19d41:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    \r\n    // Función auxiliar para obtener el perfil del usuario que está haciendo la consulta\r\n    function getUserData() {\r\n      return get(/$(database)/documents/users/$(request.auth.uid)).data;\r\n    }\r\n\r\n    // Regla para la colección de llantas\r\n    match /tires/{tireId} {\r\n      // Un usuario solo puede leer o escribir si está autenticado Y su companyId coincide con el de la llanta\r\n      allow read, write: if request.auth != null \r\n                          && resource.data.companyId == getUserData().companyId;\r\n                          \r\n      // Regla para permitir la creación si el usuario se asigna su propio companyId\r\n      allow create: if request.auth != null \r\n                     && request.resource.data.companyId == getUserData().companyId;\r\n    }\r\n\r\n    // Regla para la colección de camiones\r\n    match /trucks/{truckId} {\r\n      allow read, write: if request.auth != null \r\n                          && resource.data.companyId == getUserData().companyId;\r\n      allow create: if request.auth != null \r\n                     && request.resource.data.companyId == getUserData().companyId;\r\n    }\r\n  }\r\n}"}]}}
